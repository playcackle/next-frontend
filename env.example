# =============================================================================
# Frontend - Local/Railway Environment Configuration Example
# =============================================================================
# Copy this file to .env.local for local development, or set these variables on
# the Railway frontend service before building/deploying.
# Vite embeds VITE_* values at build time.
# =============================================================================

# === Supabase Configuration ===
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === Backend Service Public URLs ===
# Local development examples:
# VITE_LOBBY_MANAGER_URL=http://localhost:8001
# VITE_CONTENT_SERVICE_URL=http://localhost:8003
# VITE_PLAYER_SERVICE_URL=http://localhost:8004

# Railway production examples. Browsers must use public HTTPS URLs, not *.railway.internal.
VITE_LOBBY_MANAGER_URL=https://lobbymanager-production.up.railway.app
VITE_CONTENT_SERVICE_URL=https://contentmanager-production-75ae.up.railway.app
VITE_PLAYER_SERVICE_URL=https://playermanager-production.up.railway.app

# === Feature/config flags ===
VITE_LAUNCHED=true
VITE_DISCORD_URL=https://discord.gg/your-invite
