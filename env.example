# =============================================================================
# Frontend - Local Development Environment Configuration Example
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# This file is for running frontend directly with 'npm run dev'
# For Docker execution, see .env.docker.example
# =============================================================================

# === Supabase Configuration ===
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# === Service URLs - Local Dev Mode ===
# Server-side: Next.js API routes call backend (both on localhost)
LOBBY_MANAGER_INTERNAL_URL=http://localhost:8001

# Content and Player services (for admin panel)
CONTENT_SERVICE_URL=http://localhost:8003
PLAYER_SERVICE_URL=http://localhost:8004

# Client-side: Browser calls backend
NEXT_PUBLIC_LOBBY_MANAGER_URL=http://localhost:8001
# Note: Bot service is accessed via /api/admin/lobbies/{lobbyId}/bots (proxied through lobby_manager)
